  ["git", "init",     "disallowed", "Use jj init instead",               "manifest", "eternal"],
  ["git", "clone",    "disallowed", "Use jj git clone instead",          "manifest", "eternal"],
  ["git", "add",      "disallowed", "jj tracks automatically",           "manifest", "eternal"],
  ["git", "commit",   "disallowed", "Use jj commit or jj describe",     "manifest", "eternal"],
  ["git", "push",     "disallowed", "Use jj git push instead",          "manifest", "eternal"],
  ["git", "pull",     "disallowed", "Use jj git fetch instead",         "manifest", "eternal"],
  ["git", "fetch",    "disallowed", "Use jj git fetch instead",         "manifest", "eternal"],
  ["git", "branch",   "disallowed", "Use jj bookmark instead",          "manifest", "eternal"],
  ["git", "checkout", "disallowed", "Use jj new or jj edit instead",    "manifest", "eternal"],
  ["git", "merge",    "disallowed", "Use jj new with multiple parents", "manifest", "eternal"],
  ["git", "rebase",   "disallowed", "Use jj rebase instead",            "manifest", "eternal"],
  ["git", "log",      "disallowed", "Use jj log instead",               "manifest", "eternal"]
]
:put sys_command { tool, subcommand => status, description, phase, dignity }

