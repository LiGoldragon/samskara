#── Enum registry seed ─────────────────────────────────────────────────

?[name, description, phase, dignity] <- [
  ["Enum",       "Registry of all categorical type relations", "manifest", "eternal"],
  ["Phase",      "Lifecycle tri-state: manifest/becoming/retired", "manifest", "eternal"],
  ["Dignity",    "Epistemological trust hierarchy", "manifest", "eternal"],
  ["CommitType", "Jujutsu commit classification", "manifest", "eternal"],
  ["Action",     "Commit transformation verb", "manifest", "eternal"],
  ["Verdict",    "Commit context judgment", "manifest", "eternal"],
  ["Element",    "Four classical elements — fire/water/air/earth", "manifest", "eternal"],
  ["Modality",   "Three modalities — mutable/cardinal/fixed", "manifest", "eternal"],
  ["Sign",       "Twelve zodiacal signs", "manifest", "eternal"],
  ["Planet",     "Seven classical planets + nodes", "manifest", "eternal"],
  ["Rulership",  "Planet-Sign dignity assignments — domicile/exaltation/detriment/fall", "manifest", "eternal"],
  ["Aspect",     "Geometric relationships between signs", "manifest", "eternal"],
  ["SourceType", "Fetcher types for external sources — mirrors Nix fetchurl/fetchgit/etc", "manifest", "eternal"]
]
:put Enum { name => description, phase, dignity }

#Phase and Dignity seeds are loaded by samskara-core during core_genesis.

