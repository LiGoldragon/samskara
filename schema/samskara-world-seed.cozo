#── Enum registry seed ─────────────────────────────────────────────────

?[name, description] <- [
  ["Enum",       "Registry of all categorical type relations"],
  ["Phase",      "Lifecycle tri-state: manifest/becoming/retired"],
  ["Dignity",    "Epistemological trust hierarchy"],
  ["CommitType", "Jujutsu commit classification"],
  ["Action",     "Commit transformation verb"],
  ["Verdict",    "Commit context judgment"],
  ["Element",    "Four classical elements — fire/water/air/earth"],
  ["Modality",   "Three modalities — mutable/cardinal/fixed"],
  ["Sign",       "Twelve zodiacal signs"],
  ["Planet",     "Seven classical planets + nodes"],
  ["Aspect",     "Geometric relationships between signs"]
]
:put Enum { name => description }

#── Phase seed ─────────────────────────────────────────────────────────

?[name, glyph, in_world_hash, description] <- [
  ["manifest", "☉", true,  "Current, active — what IS"],
  ["becoming", "☽", false, "Staged, proposed — what is being considered"],
  ["retired",  "♄", false, "Archived, superseded — what WAS"]
]
:put Phase { name => glyph, in_world_hash, description }

#── Dignity seed ───────────────────────────────────────────────────────

?[name, rank, description] <- [
  ["eternal",   0, "Immutable, foundational invariant (nitya)"],
  ["proven",    1, "Verified through trusted source (siddha)"],
  ["seen",      2, "Witnessed, observed — default (dṛṣṭa)"],
  ["uncertain", 3, "Unverified claim (sandeha)"],
  ["delusion",  4, "Error, unreliable source (bhrama)"]
]
:put Dignity { name => rank, description }

#── CommitType seed (manifest — what kind of change) ──────────────────

?[name, description] <- [
  ["fix",       "Bug fix or correction"],
  ["feat",      "New feature or capability"],
  ["doctrine",  "Foundational invariant or principle change"],
  ["refactor",  "Restructure without behavior change"],
  ["schema",    "Relation schema change"],
  ["contract",  "Cross-component contract change"],
  ["codegen",   "Generated code or build pipeline change"],
  ["prune",     "Remove dead code or obsolete content"],
  ["doc",       "Documentation only"],
  ["nix",       "Nix flake or dev shell change"],
  ["test",      "Test addition or modification"],
  ["migrate",   "Data or naming migration"]
]
:put CommitType { name => description }

#── Action seed (becoming — what transformation verb) ─────────────────

?[name, description] <- [
  ["add",      "Introduce something new"],
  ["remove",   "Delete something entirely"],
  ["rename",   "Change the name of something"],
  ["rewrite",  "Replace content with new version"],
  ["extract",  "Pull out into its own unit"],
  ["merge",    "Combine multiple things into one"],
  ["split",    "Divide one thing into multiple"],
  ["move",     "Relocate without changing content"],
  ["replace",  "Swap one thing for another"],
  ["fix",      "Correct an error"],
  ["extend",   "Add to an existing thing"],
  ["reduce",   "Simplify or shrink"]
]
:put Action { name => description }

#── Verdict seed (retired — why the change was needed) ────────────────

?[name, description] <- [
  ["error",      "Something was wrong or broken"],
  ["evolution",  "Natural growth beyond previous form"],
  ["dependency", "Required by an upstream or downstream change"],
  ["gap",        "Missing capability or coverage"],
  ["redundancy", "Unnecessary duplication or coupling"],
  ["violation",  "Broke an invariant or principle"],
  ["drift",      "Gradual divergence from intended state"]
]
:put Verdict { name => description }

