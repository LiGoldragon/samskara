  ["proven",    "siddha",   "dignity", "Accomplished, verified"],
  ["seen",      "dṛṣṭa",   "dignity", "Witnessed, observed"],
  ["uncertain", "sandeha",  "dignity", "Doubt, unverified"],
  ["delusion",  "bhrama",   "dignity", "Error, mistaking rope for snake"],
  ["commit",    "saṅkalpa", "vcs",     "Determination, resolve"],
  ["restore",   "pratiṣṭhā","vcs",     "Establishment, restoration"],
  ["impression","saṃskāra", "core",    "Mental impression, latent tendency"]
]
:put samskrta { term => samskrta, domain, meaning }

