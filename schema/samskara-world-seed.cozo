#── sys_command_usage seed ────────────────────────────────────────────

?[tool, subcommand, notes, examples, phase, dignity] <- [
  ["jj", "init",
   "Creates a new jj repo with git backend. Creates .jj/ not .git/ directly. If .git/ already exists use jj git init --colocate instead.",
   "jj init\njj init --colocate",
   "manifest", "eternal"],
  ["jj", "new",
   "Creates a new empty change on top of current one. Previous change becomes immutable. Use after jj describe to seal a change before pushing. Can create merge commits with multiple parents.",
   "jj new\njj new @- main\njj new -m 'wip'",
   "manifest", "eternal"],
  ["jj", "describe",
   "Sets or updates the description of a change (default: @). Always pass -m to avoid interactive editor. In this project, messages are CozoScript tuple-of-three-tuples.",
   "jj describe -m '((feat, repo, scope), (add, what changed), (evolution, why))'\njj describe -m 'wip' -r @-",
   "manifest", "eternal"],
  ["jj", "commit",
   "Finalizes the current change and starts a new one in a single step. Equivalent to jj describe -m + jj new. Always pass -m.",
   "jj commit -m '((fix, repo), (update, thing), (error, was broken))'",
   "manifest", "eternal"],
  ["jj", "squash",
   "Moves changes from one revision into its parent. Useful for folding a wip change into the previous one. Without flags, squashes @ into @-.",
   "jj squash\njj squash -r @-- --into @-\njj squash --interactive",
   "manifest", "eternal"],
  ["jj", "abandon",
   "Discards a change entirely. Children are rebased onto its parent. Safe: the change is still in the operation log and can be recovered with jj undo.",
   "jj abandon\njj abandon @-\njj abandon xyzabc",
   "manifest", "eternal"],
  ["jj", "edit",
   "Switches the working copy to an existing change, making it the new @. Unlike git checkout, this does not detach. Edits go directly into the target change.",
   "jj edit @-\njj edit main\njj edit xyzabc",
   "manifest", "eternal"],
  ["jj", "log",
   "Shows the revision graph. Default template shows change id, commit id, bookmarks, description. Use -r to limit revisions shown.",
   "jj log\njj log -r 'main..@'\njj log -r 'all()' --limit 20\njj log -T 'description.first_line()'",
   "manifest", "eternal"],
  ["jj", "diff",
   "Shows the diff of a change. Default shows working copy diff. Use -r for a specific revision, --from/--to for arbitrary comparison.",
   "jj diff\njj diff -r @-\njj diff --stat\njj diff --from main",
   "manifest", "eternal"],
  ["jj", "status",
   "Shows working copy status: modified/added/removed files and current change/parent info. jj auto-tracks all files (no staging area), so this is purely informational.",
   "jj status",
   "manifest", "eternal"],
  ["jj", "bookmark",
   "Manages bookmarks (jj equivalent of git branches). Key operations: set, move, create, delete, list. In this project, main is the only bookmark. Set it to @- after describing a change.",
   "jj bookmark set main -r @-\njj bookmark list\njj bookmark create feature -r @",
   "manifest", "eternal"],
  ["jj", "git push",
   "Pushes bookmarks to the git remote. Only pushes bookmarks that have changed. Always push after setting the main bookmark.",
   "jj git push\njj git push --all\njj git push -b main",
   "manifest", "eternal"],
  ["jj", "git fetch",
   "Fetches from git remote(s) and updates tracking bookmarks. Does NOT rebase local work. Do that separately with jj rebase if needed.",
   "jj git fetch\njj git fetch --all-remotes\njj git fetch && jj rebase -d main",
   "manifest", "eternal"],
  ["jj", "git clone",
   "Clones a git repository and initializes jj tracking. Creates a colocated jj+git repo.",
   "jj git clone git@github.com:LiGoldragon/samskara.git\njj git clone https://github.com/LiGoldragon/samskara.git samskara",
   "manifest", "eternal"],
  ["jj", "rebase",
   "Moves changes to a new parent. Three modes: -r (single revision), -s (revision + descendants), -b (whole branch). Use -d to specify new destination.",
   "jj rebase -r @ -d main\njj rebase -s @- -d main\njj rebase -b feature -d main",
   "manifest", "eternal"]
]
:put sys_command_usage { tool, subcommand => notes, examples, phase, dignity }

?[tool, subcommand, notes, examples, phase, dignity] <- [
  ["nix", "develop",
   "Enters the dev shell from the repo flake.nix. Never pass --impure. Each repo shell provides required tools. Use flake output selector (dot-hash-name) for non-default shells like reader or lite.",
   "nix develop\nnix develop .<hash>reader\nnix develop .<hash>lite",
   "manifest", "eternal"],
