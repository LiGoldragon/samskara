  ["taurus",      "ML/T³",   "earth", "fixed",    "mass_control",  "Mass control",       "Establishment",      "manifest", "proven"],
  ["gemini",      "ML²/T³",  "air",   "mutable",  "power",         "Power",              "Knowledge",          "manifest", "proven"],
  ["cancer",      "L/T",     "water", "cardinal", "velocity",      "Velocity",           "Change",             "manifest", "proven"],
  ["leo",         "ML/T²",   "fire",  "fixed",    "force",         "Force",              "Being, identity",    "manifest", "proven"],
  ["virgo",       "ML²/T²",  "earth", "mutable",  "energy",        "Energy",             "Work, fact",         "manifest", "proven"],
  ["libra",       "L",       "air",   "cardinal", "position",      "Position",           "Observation",        "manifest", "proven"],
  ["scorpio",     "ML/T",    "water", "fixed",    "momentum",      "Momentum",           "Transformation",     "manifest", "proven"],
  ["sagittarius", "ML²/T",   "fire",  "mutable",  "action",        "Action",             "Hunch, intuition",   "manifest", "proven"],
