  ["git", "add",      "jj", "status",     "jj auto-tracks — no staging needed",            "manifest", "eternal"],
  ["git", "commit",   "jj", "commit",     "jj commit -m finalizes current change",         "manifest", "eternal"],
  ["git", "push",     "jj", "git push",   "jj git push pushes bookmarks to remote",        "manifest", "eternal"],
  ["git", "pull",     "jj", "git fetch",  "jj git fetch + jj rebase for pull",             "manifest", "eternal"],
  ["git", "fetch",    "jj", "git fetch",  "jj git fetch fetches from remote",              "manifest", "eternal"],
  ["git", "branch",   "jj", "bookmark",   "jj bookmark replaces git branch",               "manifest", "eternal"],
  ["git", "checkout", "jj", "new",        "jj new or jj edit replaces checkout",            "manifest", "eternal"],
  ["git", "merge",    "jj", "new",        "jj new rev1 rev2 creates merge change",          "manifest", "eternal"],
  ["git", "rebase",   "jj", "rebase",     "jj rebase -r/-s/-b for rebasing",               "manifest", "eternal"],
  ["git", "log",      "jj", "log",        "jj log shows revision history",                  "manifest", "eternal"]
]
