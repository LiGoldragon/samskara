#── Principle seed (doctrine) ──────────────────────────────────────

?[id, domain, rule, reason, phase, dignity] <- [
  ["p1", "data-ownership",   "Samskara NEVER sees files, code, or the OS — only relations",              "Pure datalog agent invariant",                      "manifest", "eternal"],
  ["p2", "data-ownership",   "Each agent owns its own CozoDB — no shared database access",               "Sema data ownership principle",                     "manifest", "eternal"],
  ["p3", "communication",    "Communication is ONLY through contract relations",                         "No RPC, no message bus, no shared state",           "manifest", "eternal"],
  ["p4", "vcs",              "Jujutsu for VCS — git is storage backend only",                            "jj is the only allowed interface",                  "manifest", "eternal"],
  ["p5", "build",            "Nix for builds, Rust for code — no exceptions",                            "Language policy",                                   "manifest", "eternal"],
  ["p6", "architecture",     "Micro-repo style: each concern is its own repo, contracts too",            "Separation of concerns at repo boundary",           "manifest", "eternal"],
  ["p7", "serialization",    "Binary format is Cap'n Proto — headerless data indexed by reader version", "Zero-copy, deterministic, self-describing envelope", "manifest", "eternal"],
  ["p8", "version-control",  "samskara-vcs version-controls database changes, not files",                "Relations are the unit of change, not files",       "manifest", "eternal"]
]
:put principle { id => domain, rule, reason, phase, dignity }

#── Thought seed ────────────────────────────────────────────────────

?[id, kind, scope, status, title, body, created_ts, updated_ts, phase, dignity] <- [
  ["t-user-1", "user", "global", "approved", "Project owner: Li",
   "mail@ligoldragon.com. Mentci creator. Prefers jj-centric workflow, Rust-only policy, datalog-native design.",
   "2026-03-16", "2026-03-16", "manifest", "proven"],
  ["t-project-1", "project", "global", "approved", "Mentci v1 is successor to Mentci-AI (now Mentci-v0)",
   "Original at criome/Mentci renamed to criome/Mentci-v0. New project at LiGoldragon/Mentci. Two-agent architecture: Samskara (pure datalog) + Lojix (DSL transpiler).",
   "2026-03-16", "2026-03-16", "manifest", "proven"],
  ["t-project-2", "project", "lojix", "draft", "DSL design needed",
   "Lojix has no transpile logic yet — all stubs. No DSL source relations exist. The lojix_source relation is defined but nothing populates it. DSL grammar is the next design task.",
   "2026-03-16", "2026-03-16", "becoming", "seen"],
  ["t-observation-1", "observation", "global", "approved", "jj submodules do not exist yet",
   "jj 0.36.0 has no submodule support. Tracked in jj-vcs/jj issue 494. Design doc exists but no implementation. Current workaround: Nix flake inputs for hermetic builds, sibling path deps for local dev.",
   "2026-03-16", "2026-03-16", "manifest", "proven"],
  ["t-reference-1", "reference", "global", "approved", "FAVA Trails — inspiration for agent memory",
   "github.com/MachineWisdomAI/fava-trails. MCP server for versioned agent memory using jj-tracked markdown. Key patterns: supersession, trust gate, typed relationships, draft isolation. Our datalog approach is strictly more powerful than their file-based emulation.",
   "2026-03-16", "2026-03-16", "manifest", "seen"],
  ["t-feedback-1", "feedback", "global", "approved", "git is storage, jj is the only interface",
   "Never use git commands directly. jj is mandatory for all VCS operations across all repos. Why: user's explicit requirement for jj-centric workflow. How to apply: all VCS operations use jj, all documentation references jj.",
   "2026-03-16", "2026-03-16", "manifest", "eternal"]
]
:put thought { id => kind, scope, status, title, body, created_ts, updated_ts, phase, dignity }

