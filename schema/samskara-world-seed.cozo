   "Builds a flake output. Never pass --impure. Default builds packages.default. Use dot-hash-name to select specific outputs.",
   "nix build\nnix build .<hash>samskara\nnix build --print-out-paths",
   "manifest", "eternal"],
  ["nix", "flake update",
   "Updates all flake input locks to latest. Run in Mentci after pushing upstream repos to pick up changes.",
   "nix flake update",
   "manifest", "eternal"],
  ["nix", "flake lock",
   "Updates a specific flake input lock. More targeted than full update.",
